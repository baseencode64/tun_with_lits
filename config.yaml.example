# GoXRay VPN Client Configuration File
# This file contains all available configuration options.
# CLI arguments will override values specified here.

# Connection settings
connection:
  # Direct VLESS link (use EITHER this OR from_raw/from_raw_urls, not both)
  # link: "vless://uuid@hostname:443?type=ws&path=/path&security=tls&..."
  
  # Single raw URL for server list (legacy, use from_raw_urls for multiple URLs)
  # from_raw: "https://example.com/links.txt"
  
  # Multiple raw URLs with automatic fallback
  # If first URL fails, tries next ones in order
  from_raw_urls:
    - "https://example.com/links1.txt"
    - "https://backup.example.com/links2.txt"
    - "https://mirror.example.com/links3.txt"
  
  # Enable IPv6 support (default: false)
  enable_ipv6: false
  
  # Allow insecure TLS certificates (default: false)
  tls_allow_insecure: false

# Server selection and refresh settings
server_selection:
  # Periodically refresh server list (e.g., "5m", "10m", "1h")
  # Set to empty string or remove to disable periodic refresh
  refresh_interval: "10m"
  
  # Maximum number of servers to check (default: 10)
  max_servers: 10
  
  # Timeout per server health check (default: "5s")
  timeout: "5s"

# Reconnection settings (persistence & auto-reconnect)
# Controls behavior when all servers in the list are exhausted.
# The client will re-fetch the server list and retry with exponential backoff.
reconnection:
  # Max reconnection attempts (0 = unlimited retries, default: 0)
  max_retries: 0
  
  # Initial backoff duration (default: "5s")
  # After first failure, waits this long before retrying
  min_backoff: "5s"
  
  # Maximum backoff duration (default: "5m")
  # Backoff grows exponentially up to this limit
  max_backoff: "5m"
  
  # Exponential backoff multiplier (default: 2.0)
  # Each retry waits: min_backoff * backoff_factor^attempt (capped at max_backoff)
  backoff_factor: 2.0

# Logging configuration
logging:
  # Log format: "text" or "json" (default: "text")
  format: "text"
  
  # Log level: "debug", "info", "warn", or "error" (default: "info")
  level: "info"
  
  # Log file path (optional, default: stdout only)
  # file: "/var/log/goxray/goxray.log"
  
  # Max log file size in MB before rotation (default: 100)
  max_size: 100
  
  # Max number of backup log files (default: 3)
  max_backups: 3
  
  # Max age of backup logs in days (default: 28)
  max_age: 28

# Health monitoring settings
health_monitoring:
  # Health check interval (default: "10s")
  check_interval: "10s"
  
  # Health check timeout (default: "5s")
  timeout: "5s"
  
  # Max retries before failover (default: 3)
  max_retries: 3